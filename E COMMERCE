#include <iostream>
using namespace std;

class Product
{
private:
    string productName;
    float price;
    int quantity;

public:
    void getData()
    {
        cout << "Enter Product Name: ";
        cin >> productName;

        cout << "Enter Price: ";
        cin >> price;

        cout << "Enter Quantity: ";
        cin >> quantity;

        if (price < 0)
            price = 0;

        if (quantity < 0)
            quantity = 0;
    }

    float calculateTotal()
    {
        return price * quantity;
    }

    void display()
    {
        cout << "\nProduct Name: " << productName;
        cout << "\nPrice: " << price;
        cout << "\nQuantity: " << quantity;
        cout << "\nCost: " << calculateTotal() << endl;
    }
};

int main()
{
    int n;
    float totalBill = 0;

    cout << "Enter Number of Products: ";
    cin >> n;

    Product p[10];

    for (int i = 0; i < n; i++)
    {
        cout << "\nEnter Details of Product " << i + 1 << endl;
        p[i].getData();
    }

    cout << "\n--- Shopping Cart Details ---\n";

    for (int i = 0; i < n; i++)
    {
        p[i].display();
        totalBill += p[i].calculateTotal();
    }

    cout << "\nTotal Products: " << n;
    cout << "\nTotal Bill = " << totalBill << endl;

    return 0;
}
